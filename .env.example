# ============================================
# Telegram AI Agent Bot - Environment Variables
# ============================================

# Telegram Bot Token (required)
# Get from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# ============================================
# AI Provider Configuration (required for AI features)
# ============================================
# Choose one provider. Groq is FREE and recommended.
#
# Option 1: Groq (FREE - recommended)
# Get key: https://console.groq.com/keys
AI_PROVIDER=groq
AI_API_KEY=your_groq_api_key_here
# AI_MODEL=llama-3.3-70b-versatile  # optional, has default
#
# Option 2: OpenAI
# AI_PROVIDER=openai
# AI_API_KEY=sk-...
# AI_MODEL=gpt-4o-mini
#
# Option 3: OpenRouter (has free models)
# AI_PROVIDER=openrouter
# AI_API_KEY=sk-or-...
# AI_MODEL=meta-llama/llama-3.3-70b-instruct:free
#
# Option 4: Together AI
# AI_PROVIDER=together
# AI_API_KEY=...
# AI_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo-Free
#
# Option 5: Custom OpenAI-compatible
# AI_PROVIDER=custom
# AI_BASE_URL=https://your-api-endpoint.com/v1
# AI_API_KEY=...
# AI_MODEL=your-model-name

# ============================================
# Z.ai SDK (internal use only - works inside Z.ai infrastructure)
# ============================================
# ZAI_BASE_URL=https://internal-api.z.ai/v1
# ZAI_API_KEY=Z.ai
# ZAI_TOKEN=
# ZAI_CHAT_ID=
# ZAI_USER_ID=

# ============================================
# Bot Configuration (optional, has defaults)
# ============================================
BOT_USERNAME=AICodingAgentBot
MAX_TOKENS=4096
TEMPERATURE=0.7
MAX_HISTORY=20
HISTORY_TTL=3600
RATE_LIMIT=10
COOLDOWN=5
ADMIN_USERS=
NODE_ENV=production

# ============================================
# Premium Features (optional)
# ============================================
# Comma-separated Telegram user IDs that get unlimited access
# Get your ID by messaging @userinfobot on Telegram
PREMIUM_USER_IDS=

# ============================================
# Vision & Multi-Model Routing (auto-defaulted per provider)
# ============================================
# Override if you want different models
# AI_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# AI_FAST_MODEL=llama-3.1-8b-instant

# ============================================
# Web Search (DuckDuckGo is free default; Tavily/Serper optional upgrades)
# ============================================
# TAVILY_API_KEY=tvly-...  (1000 req/month free — https://tavily.com)
# SERPER_API_KEY=...       (2500 req/month free — https://serper.dev)

# ============================================
# Code Sandbox (Judge0 CE — free, no API key needed)
# ============================================
# Backend: judge0 (default, recommended) | wandbox | piston (self-host only)
# SANDBOX_BACKEND=judge0
# SANDBOX_API_URL=https://ce.judge0.com  (override if self-hosting)
# SANDBOX_TIMEOUT=10000

# ============================================
# Storage (long-term memory + usage counters)
# ============================================
# MEMORY_DIR=./data
