# ============================================
# Telegram AI Agent Bot - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# REQUIRED: Your Telegram Bot Token (get from @BotFather)
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# REQUIRED (for Railway/production): ZAI SDK Configuration
ZAI_BASE_URL=https://internal-api.z.ai/v1
ZAI_API_KEY=Z.ai
ZAI_TOKEN=your_zai_token_here

# OPTIONAL: Bot username (without @)
BOT_USERNAME=AICodingAgentBot

# OPTIONAL: AI Model
AI_MODEL=default

# OPTIONAL: Max tokens for AI responses
MAX_TOKENS=4096

# OPTIONAL: AI Temperature (0.0 - 1.0, lower = more precise)
TEMPERATURE=0.7

# OPTIONAL: Max messages in conversation history
MAX_HISTORY=20

# OPTIONAL: History TTL in seconds (default: 3600 = 1 hour)
HISTORY_TTL=3600

# OPTIONAL: Max requests per minute per user
RATE_LIMIT=10

# OPTIONAL: Cooldown between requests in seconds
COOLDOWN=5

# OPTIONAL: Admin Telegram user IDs (comma-separated)
ADMIN_USERS=
